# Banco de dados (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5436/ccmf?schema=public"

# Auth.js (gerar com: openssl rand -base64 32)
AUTH_SECRET=""

# URL pública da aplicação
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# S3 (AWS ou compatível: MinIO, Cloudflare R2, etc.)
S3_REGION="us-east-1"
S3_BUCKET="ccmf-media"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# opcional: endpoint customizado para provedores compatíveis com S3
S3_ENDPOINT=""
# base pública para servir as imagens (CDN/CloudFront)
S3_PUBLIC_URL="https://ccmf-media.s3.amazonaws.com"

# Asaas (gateway de pagamento)
# sandbox: https://api-sandbox.asaas.com/v3 | produção: https://api.asaas.com/v3
ASAAS_BASE_URL="https://api-sandbox.asaas.com/v3"
# ATENÇÃO: a chave do Asaas começa com "$" — escape com "\$" para o Next.js
# não tratar como expansão de variável (ex.: ASAAS_API_KEY="\$aact_...")
ASAAS_API_KEY=""
# token configurado no painel do Asaas para validar webhooks (header asaas-access-token)
ASAAS_WEBHOOK_TOKEN=""
